VITE_N8N_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-chat
# Documentos (DP_Trabalhista_Documentos_API): GET -> array com vigencias
VITE_DOCS_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-documentos
# Ingestao de CCT (DP_Trabalhista_Ingestao_API): POST { filename, content|file_base64 }
VITE_INGEST_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-ingest
# Compartilhamento de conversa (DP_Trabalhista_Share)
VITE_SHARE_SAVE_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-share-save
VITE_SHARE_GET_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-share-get

# --- Login (validado no servidor; senha NAO fica no bundle) ---
