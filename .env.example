# URL do webhook do n8n que recebe as mensagens do chat.
# Em producao use a URL de "Production" do node Webhook; em teste, a de "Test".
VITE_N8N_WEBHOOK_URL=https://SEU-N8N/webhook/trabalhista-chat

# URL do webhook do n8n que devolve os documentos (CCTs) com suas vigencias,
# usado pela aba "Vencimentos". Deve responder um array de documentos com
# campos: titulo, tipo/sindicato/base (ou metadata), vigencia_de, vigencia_ate.
VITE_DOCS_WEBHOOK_URL=https://SEU-N8N/webhook/trabalhista-documentos
