# URL do webhook de chat do n8n (workflow DP_Trabalhista_Chat_API).
# Recebe POST { message, sessionId } e responde { reply }.
VITE_N8N_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-chat

# URL do webhook de documentos do n8n (workflow DP_Trabalhista_Documentos_API).
# Responde um array de documentos (CCTs) com vigencia_de/ate para a aba "Vencimentos".
VITE_DOCS_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-documentos
