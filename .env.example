# --- Webhooks n8n ---
# Chat (workflow DP_Trabalhista_Chat_API): POST { message, sessionId } -> { reply }
VITE_N8N_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-chat
# Documentos (DP_Trabalhista_Documentos_API): GET -> array com vigencias
VITE_DOCS_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-documentos
# Ingestao de CCT (DP_Trabalhista_Ingestao_API): POST multipart (file .md) -> grava no bucket e dispara ingest
VITE_INGEST_WEBHOOK_URL=https://webhook.vps.central-rnc.com.br/webhook/trabalhista-ingest

# --- Login (barreira simples client-side) ---
# Deixe ambas vazias para liberar o acesso (sem login).
# E-mails autorizados, separados por virgula:
VITE_AUTH_USERS=usuario1@exemplo.com,usuario2@exemplo.com
# Senha compartilhada (NAO comite a senha real; preencha so no .env local):
VITE_AUTH_PASSWORD=troque-esta-senha
